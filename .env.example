# =====================================================================
# Doness — Environment Variables (Template)
# ---------------------------------------------------------------------
# 본 파일은 git 에 커밋된다. 실제 값은 `.env` 에 작성하며 절대 노출 금지.
# `.env` 와 `.env.example` 은 **항상 동일한 키셋** 을 유지해야 한다.
# 새 키를 추가하거나 제거할 때 양쪽을 동시에 갱신할 것.
# 자세한 규약은 /GUIDELINE.md §8 "보안 / 환경 변수" 참조.
# =====================================================================

# ── Network ──────────────────────────────────────────────────────────
NETWORK_BRIDGE=doness-net

# ── Gateway (Nginx) ──────────────────────────────────────────────────
NGINX_PORT=18080

# ── Frontend ─────────────────────────────────────────────────────────
FRONTEND_PORT=5173

# ── Backend ──────────────────────────────────────────────────────────
BACKEND_PORT=8080
# 외부에서 보이는 공개 URL (절대경로 redirect / 이메일 링크 생성 등에 사용)
BACKEND_PUBLIC_URL=http://localhost:18080

# ── Database (Postgres) ──────────────────────────────────────────────
DB_HOST=database
DB_PORT=5432              # 컨테이너 내부 포트
DB_PORT_HOST=15432        # 호스트 노출 포트 (DB 클라이언트 접속용)
DB_NAME=doness
DB_USER=doness
# 강한 랜덤 값을 .env 에 채울 것. 비워둔 채로 git 커밋하지 말 것.
DB_PASSWORD=<change-me>

# ── Auth / Secret Keys ───────────────────────────────────────────────
# 모두 충분한 엔트로피의 랜덤 값으로 .env 에서 채울 것 (예: openssl rand -hex 32).
# 코드 어디에도 하드코딩 금지. 반드시 본 변수 참조.
JWT_SECRET=<change-me>
SESSION_SECRET=<change-me>

# ── Wiki (Docusaurus, Private 영역 Basic Auth) ───────────────────────
WIKI_AUTH_USER=<change-me>
WIKI_AUTH_PASS=<change-me>

# ── Timezone ─────────────────────────────────────────────────────────
APP_TIMEZONE=Asia/Seoul
TZ=Asia/Seoul
